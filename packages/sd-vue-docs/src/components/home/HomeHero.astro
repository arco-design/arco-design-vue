---
import { docsSidebar } from "../../generated/docs-sidebar";

type SidebarItem = {
  slug?: string;
  items?: SidebarItem[];
};

const countComponentDocs = (items: SidebarItem[]): number => {
  return items.reduce((total, item) => {
    const current = item.slug?.startsWith("components/") ? 1 : 0;
    const nested = item.items ? countComponentDocs(item.items) : 0;
    return total + current + nested;
  }, 0);
};

const componentCount = countComponentDocs(docsSidebar as SidebarItem[]);

const quickLinks = [
  {
    title: "快速上手",
    description: "从安装、按需引入到基础使用，先把组件库接进项目。",
    href: "/guides/start/",
    badge: "Guide",
  },
  {
    title: "定制主题",
    description: "基于 scss 变量覆盖现有主题，接入你的业务品牌色体系。",
    href: "/guides/theme/",
    badge: "Theme",
  },
  {
    title: "暗黑模式",
    description: "文档站与组件库暗黑态联动，统一查看亮暗主题效果。",
    href: "/guides/dark/",
    badge: "Dark",
  },
];
---

<section class="home-hero">
  <div class="home-hero__copy">
    <p class="home-hero__eyebrow">企业级 Vue 组件文档与设计实践</p>
    <h1>SD Design</h1>
    <p class="home-hero__slogan">
      AI 原生设计系统，让开发更具「灵感」与「效率」。 现已拥有「{
        componentCount
      }」个组件。
    </p>

    <div class="home-hero__actions">
      <a
        class="home-hero__button home-hero__button--primary"
        href="/guides/start/">开始使用</a
      >
      <a class="home-hero__button" href="/design/guidelines/">设计语言</a>
    </div>
  </div>

  <div class="home-hero__links">
    {
      quickLinks.map((item) => (
        <a class="home-hero__card" href={item.href}>
          <span class="home-hero__badge">{item.badge}</span>
          <strong>{item.title}</strong>
          <p>{item.description}</p>
        </a>
      ))
    }
  </div>
</section>

<style>
  .home-hero {
    position: relative;
    overflow: clip;
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    padding: clamp(2rem, 6vw, 4.5rem);
    border-radius: 2rem;
    background:
      radial-gradient(
        circle at 12% 18%,
        rgb(20 118 255 / 0.18),
        transparent 28%
      ),
      radial-gradient(
        circle at 88% 20%,
        rgb(53 208 127 / 0.12),
        transparent 22%
      ),
      linear-gradient(180deg, rgb(255 255 255 / 0.92), rgb(246 250 255 / 0.98));
    border: 1px solid rgb(20 118 255 / 0.12);
    box-shadow: 0 30px 80px rgb(20 118 255 / 0.08);
  }

  .home-hero__halo {
    position: absolute;
    width: 24rem;
    aspect-ratio: 1;
    border-radius: 999px;
    filter: blur(34px);
    opacity: 0.42;
    pointer-events: none;
  }

  .home-hero__copy {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1rem;
    max-width: var(--sl-content-width);
    margin-inline: auto;
  }

  .home-hero__eyebrow {
    margin: 0;
    color: var(--sl-color-accent-high);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .home-hero h1 {
    margin: 0;
    font-size: clamp(3rem, 9vw, 5.8rem);
    line-height: 0.92;
    letter-spacing: -0.08em;
  }

  .home-hero__slogan {
    margin: 0;
    max-width: 46rem;
    font-size: clamp(1.05rem, 2.6vw, 1.35rem);
    line-height: 1.8;
    color: var(--sl-text-2);
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-top: 0.5rem;
  }

  .home-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 8rem;
    padding: 0.9rem 1.35rem;
    border-radius: 999px;
    border: 1px solid rgb(20 118 255 / 0.18);
    color: var(--sl-color-text);
    background: rgb(255 255 255 / 0.82);
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .home-hero__button:hover {
    transform: translateY(-1px);
    border-color: rgb(20 118 255 / 0.4);
  }

  .home-hero__button--primary {
    color: white;
    background: linear-gradient(135deg, #1476ff, #0d4fbf);
    border-color: transparent;
  }

  .home-hero__links {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    max-width: var(--sl-content-width);
    margin-inline: auto;
  }

  .home-hero__card {
    display: grid;
    gap: 0.7rem;
    padding: 1.15rem 1.2rem;
    border-radius: 1.25rem;
    text-decoration: none;
    color: inherit;
    background: color-mix(in srgb, white 84%, transparent);
    border: 1px solid rgb(20 118 255 / 0.1);
    backdrop-filter: blur(12px);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .home-hero__card:hover {
    transform: translateY(-2px);
    border-color: rgb(20 118 255 / 0.28);
    background: white;
  }

  .home-hero__badge {
    display: inline-flex;
    width: fit-content;
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    background: rgb(20 118 255 / 0.1);
    color: var(--sl-color-accent-high);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .home-hero__card strong {
    font-size: 1.1rem;
  }

  .home-hero__card p {
    margin: 0;
    color: var(--sl-text-3);
    line-height: 1.7;
  }

  :root[data-theme="dark"] .home-hero {
    background:
      radial-gradient(
        circle at 12% 18%,
        rgb(97 168 255 / 0.18),
        transparent 28%
      ),
      radial-gradient(
        circle at 88% 20%,
        rgb(53 208 127 / 0.14),
        transparent 22%
      ),
      linear-gradient(180deg, rgb(7 17 31 / 0.96), rgb(11 18 32 / 0.98));
    border-color: rgb(97 168 255 / 0.14);
    box-shadow: 0 34px 100px rgb(0 0 0 / 0.34);
  }

  :root[data-theme="dark"] .home-hero__button,
  :root[data-theme="dark"] .home-hero__card {
    background: rgb(255 255 255 / 0.04);
    border-color: rgb(255 255 255 / 0.1);
  }

  :root[data-theme="dark"] .home-hero__button:hover,
  :root[data-theme="dark"] .home-hero__card:hover {
    background: rgb(255 255 255 / 0.08);
  }

  :root[data-theme="dark"] .home-hero__button--primary {
    border-color: transparent;
    background: linear-gradient(135deg, #61a8ff, #2c66d2);
  }

  @media (max-width: 900px) {
    .home-hero__links {
      grid-template-columns: 1fr;
    }
  }
</style>
