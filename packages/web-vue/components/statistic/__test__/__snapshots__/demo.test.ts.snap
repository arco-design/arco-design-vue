// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`<statistic> demo: > render [animation] correctly 1`] = `
<div class="sd-statistic">
  <div class="sd-statistic-title">User Growth Rate</div>
  <div class="sd-statistic-content">
    <div class="sd-statistic-value"><span class="sd-statistic-prefix"><svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" viewBox="0 0 48 48" class="sd-icon sd-icon-arrow-rise" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter"><path d="M23.992 6.01a.01.01 0 0 1 .016 0l9.978 11.974a.01.01 0 0 1-.007.016H14.02a.01.01 0 0 1-.007-.016z"></path><path fill="currentColor" stroke="none" d="m24 6 10 12H14z"></path><path d="M26 42h-4V16h4z"></path><path fill="currentColor" stroke="none" d="M26 42h-4V16h4z"></path></svg></span><span class="sd-statistic-value-integer">0</span><span class="sd-statistic-value-decimal"> .00</span><span class="sd-statistic-suffix">%</span></div>
    <!--v-if-->
  </div>
</div>
<button class="sd-btn sd-btn-secondary sd-btn-shape-square sd-btn-size-medium sd-btn-status-normal" type="button">
  <!--v-if-->Start
</button>
`;

exports[`<statistic> demo: > render [basic] correctly 1`] = `
<div class="sd-space sd-space-horizontal sd-space-align-center" style="column-gap: 24px; row-gap: 24px;">
  <!---->
  <div class="sd-space-item">
    <div class="sd-statistic">
      <div class="sd-statistic-title">Downloads</div>
      <div class="sd-statistic-content">
        <div class="sd-statistic-value">
          <!--v-if--><span class="sd-statistic-value-integer">125,670</span>
          <!--v-if-->
          <!--v-if-->
        </div>
        <!--v-if-->
      </div>
    </div>
  </div>
  <!---->
  <div class="sd-space-item">
    <div class="sd-statistic">
      <!--v-if-->
      <div class="sd-statistic-content">
        <div class="sd-statistic-value">
          <!--v-if--><span class="sd-statistic-value-integer">40509</span><span class="sd-statistic-value-decimal"> .00</span>
          <!--v-if-->
        </div>
        <div class="sd-statistic-extra">Comments</div>
      </div>
    </div>
  </div>
</div>
`;

exports[`<statistic> demo: > render [countdown] correctly 1`] = `
<div class="sd-row sd-row-align-start sd-row-justify-start">
  <div class="sd-col" style="flex: 1 1 0%;">
    <div class="sd-statistic sd-statistic-countdown">
      <div class="sd-statistic-title">Countdown</div>
      <div class="sd-statistic-content">
        <div class="sd-statistic-value">02:00:00</div>
      </div>
    </div>
  </div>
  <div class="sd-col" style="flex: 1 1 0%;">
    <div class="sd-statistic sd-statistic-countdown">
      <div class="sd-statistic-title">Milliseconds</div>
      <div class="sd-statistic-content">
        <div class="sd-statistic-value">02:00:00.000</div>
      </div>
    </div>
  </div>
  <div class="sd-col" style="flex: 1 1 0%;">
    <div class="sd-statistic sd-statistic-countdown">
      <div class="sd-statistic-title">Days</div>
      <div class="sd-statistic-content">
        <div class="sd-statistic-value">4 天 0 时 0 分 0 秒</div>
      </div>
    </div>
  </div>
</div>
<div class="sd-space sd-space-vertical sd:mt-2.5" style="column-gap: 8px; row-gap: 8px;">
  <!---->
  <div class="sd-space-item">
    <div class="sd-statistic sd-statistic-countdown">
      <div class="sd-statistic-title">Trigger on finish</div>
      <div class="sd-statistic-content">
        <div class="sd-statistic-value">00:05.000</div>
      </div>
    </div>
  </div>
  <!---->
  <div class="sd-space-item"><button class="sd-btn sd-btn-primary sd-btn-shape-square sd-btn-size-medium sd-btn-status-normal" type="button">
      <!--v-if-->Start
    </button></div>
</div>
`;

