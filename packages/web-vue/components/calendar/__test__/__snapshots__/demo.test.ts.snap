<!-- ========== 阻止时间段 (allowEvents) ========== -->
<section class="sd:mb-8">
  <h3 class="sd:text-lg sd:font-semibold sd:mb-3">阻止时间段 (allowEvents)</h3>
  <p class="sd:mb-3 sd:text-sm sd:text-gray-600"> 在 <code>special-hours</code> 的时间块上设置 <code>allowEvents: false</code> 可阻止该时间段内的事件创建/拖入/缩放。 适合午餐时间、休息时间等不可预约时段。 </p>
  <div data-locale="" class="sd-calendar sd-calendar--ready sd-calendar--default-theme sd-calendar--lg sd-calendar--light sd-calendar--week-view sd-calendar--view-has-time" style="--sd-calendar-time-cell-size: 40px; --sd-calendar-schedules-count: 0; height: 400px;">
    <div class="sd-calendar__header">
      <div class="sd-calendar__views-bar"><button class="sd-calendar__view-button sd-calendar__view-button--active" type="button">周</button></div>
      <nav class="sd-calendar__title-bar"><button class="sd-calendar__nav sd-calendar__nav--prev sd-calendar__nav--default" type="button"></button>
        <div class="sd-calendar__transition-wrap">
          <transition-stub name="sd-calendar-slide-fade--right" appear="false" persisted="false" css="true">
            <div>
              <div class="sd-calendar__title">六月 8-14, 2026<small>&nbsp;周 24</small></div>
            </div>
          </transition-stub>
        </div><button disabled="" class="sd-calendar__nav sd-calendar__nav--today sd-calendar__nav--default sd-calendar__nav--active" type="button">今天</button><button class="sd-calendar__nav sd-calendar__nav--next sd-calendar__nav--default" type="button"></button>
      </nav>
    </div>
    <div class="sd-calendar__scrollable-wrap">
      <transition-stub name="sd-calendar-slide-fade--right" appear="false" persisted="false" css="true">
        <div class="sd-scrollbar sd-scrollbar-type-embed sd-calendar__scrollable sd-calendar__scrollable--row sd-calendar__scrollable--week-view sd-calendar__scrollable--no-schedules sd-calendar__scrollable--no-all-day-bar">
          <div class="sd-scrollbar-container sd-calendar__scrollable-content" data-overlayscrollbars="host">
            <div class="" data-overlayscrollbars-viewport="scrollbarHidden overflowXHidden overflowYHidden" tabindex="-1" style="top: 0px; right: auto; left: 0px; width: calc(100% + 0px); margin-right: 0px; margin-bottom: 0px; margin-left: 0px; padding: 0px;">
              <div class="sd-calendar__time-column">
                <div class="sd-calendar__time-column-inner">
                  <!--v-if-->
                  <div class="sd-calendar__time-cell"><label>07:00</label></div>
                  <div class="sd-calendar__time-cell"><label>08:00</label></div>
                  <div class="sd-calendar__time-cell"><label>09:00</label></div>
                  <div class="sd-calendar__time-cell"><label>10:00</label></div>
