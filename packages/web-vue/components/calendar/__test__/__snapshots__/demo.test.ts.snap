<section class="sd:mb-8">
  <h3 class="sd:text-lg sd:font-semibold sd:mb-3">暗色模式</h3>
  <p class="sd:mb-3 sd:text-sm sd:text-gray-600"> 通过 <code>ThemeProvider</code> 的 <code>theme-mode</code> 属性切换到暗色主题。 </p>
  <div class="sd:flex sd:items-center sd:gap-2 sd:mb-3"><span class="sd:text-sm sd:text-gray-500">主题模式:</span><span class="sd-radio-group-button sd-radio-group-size-medium sd-radio-group-direction-horizontal"><label class="sd-radio-button"><input type="radio" class="sd-radio-target" value="light"><span class="sd-radio-button-content">Light</span></label><label class="sd-radio-button sd-radio-checked"><input type="radio" checked="" class="sd-radio-target" value="dark"><span class="sd-radio-button-content">Dark</span></label></span></div>
  <div class="sd-theme-provider" sd-theme="dark">
    <div class="sd:bg-gray-900">
      <div data-locale="" class="sd-calendar sd-calendar--ready sd-calendar--default-theme sd-calendar--lg sd-calendar--dark sd-calendar--week-view sd-calendar--view-has-time" style="--sd-calendar-time-cell-size: 40px; --sd-calendar-schedules-count: 0; height: 420px;">
