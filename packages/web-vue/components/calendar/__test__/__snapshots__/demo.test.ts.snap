<!-- ========== 多视图切换 ========== -->
<section class="sd:mb-8">
  <h3 class="sd:text-lg sd:font-semibold sd:mb-3">多视图切换</h3>
  <p class="sd:mb-3 sd:text-sm sd:text-gray-600"> 通过 <code>views</code> 属性控制可用的视图集合，<code>view</code> 设置当前默认视图。支持 <code>day</code>、<code>days</code>、<code>week</code>、<code>month</code>、<code>year</code>、<code>years</code>。 </p>
  <div class="sd:flex sd:flex-wrap sd:gap-2 sd:mb-3"><span class="sd:text-sm sd:text-gray-500 sd:self-center">选择视图:</span><label aria-disabled="false" class="sd-checkbox sd-checkbox-checked"><input type="checkbox" checked="" class="sd-checkbox-target" value="day"><span class="sd-icon-hover sd-icon-hover-disabled sd-checkbox-icon-hover"><div class="sd-checkbox-icon"><svg aria-hidden="true" focusable="false" viewBox="0 0 1024 1024" width="200" height="200" fill="currentColor" class="sd-checkbox-icon-check"><path d="M877.44815445 206.10060629a64.72691371 64.72691371 0 0 0-95.14856334 4.01306852L380.73381888 685.46812814 235.22771741 533.48933518a64.72691371 64.72691371 0 0 0-92.43003222-1.03563036l-45.82665557 45.82665443a64.72691371 64.72691371 0 0 0-0.90617629 90.61767965l239.61903446 250.10479331a64.72691371 64.72691371 0 0 0 71.19960405 15.14609778 64.33855261 64.33855261 0 0 0 35.08198741-21.23042702l36.24707186-42.71976334 40.5190474-40.77795556-3.36579926-3.49525333 411.40426297-486.74638962a64.72691371 64.72691371 0 0 0-3.88361443-87.64024149l-45.3088404-45.43829334z" p-id="840"></path></svg></div></span><span class="sd-checkbox-label">日</span></label><label class="sd-checkbox"><input type="checkbox" class="sd-checkbox-target" value="days"><span class="sd-icon-hover sd-checkbox-icon-hover"><div class="sd-checkbox-icon"><!----></div></span><span class="sd-checkbox-label">多日</span></label><label aria-disabled="false" class="sd-checkbox sd-checkbox-checked"><input type="checkbox" checked="" class="sd-checkbox-target" value="week"><span class="sd-icon-hover sd-icon-hover-disabled sd-checkbox-icon-hover"><div class="sd-checkbox-icon"><svg aria-hidden="true" focusable="false" viewBox="0 0 1024 1024" width="200" height="200" fill="currentColor" class="sd-checkbox-icon-check"><path d="M877.44815445 206.10060629a64.72691371 64.72691371 0 0 0-95.14856334 4.01306852L380.73381888 685.46812814 235.22771741 533.48933518a64.72691371 64.72691371 0 0 0-92.43003222-1.03563036l-4