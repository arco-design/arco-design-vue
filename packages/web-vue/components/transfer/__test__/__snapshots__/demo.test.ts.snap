                          <div class="sd-transfer-list-item"><label class="sd-checkbox sd-transfer-list-item-content sd-transfer-list-item-checkbox"><input type="checkbox" class="sd-checkbox-target" value="option2"><span class="sd-icon-hover sd-checkbox-icon-hover"><div class="sd-checkbox-icon"><!----></div></span><span class="sd-checkbox-label">Option 2</span></label>
