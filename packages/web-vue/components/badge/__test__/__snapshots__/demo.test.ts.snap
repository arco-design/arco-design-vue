// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`<badge> demo: > render [alone] correctly 1`] = `
<div class="sd-space sd-space-horizontal sd-space-align-center" style="column-gap: 40px; row-gap: 40px;">
  <!---->
  <div class="sd-space-item"><span class="sd-badge sd-badge-no-children"><!----><span class="sd-badge-number"><span>2</span></span></span></div>
  <!---->
  <div class="sd-space-item"><span class="sd-badge sd-badge-no-children"><!----><span class="sd-badge-number" style="background: rgb(229, 230, 235); color: rgb(134, 144, 156);"><span>2</span></span></span></div>
  <!---->
  <div class="sd-space-item"><span class="sd-badge sd-badge-no-children"><!----><span class="sd-badge-number"><span>16</span></span></span></div>
  <!---->
  <div class="sd-space-item"><span class="sd-badge sd-badge-no-children"><!----><span class="sd-badge-number"><span>99+</span></span></span></div>
</div>
`;

exports[`<badge> demo: > render [basic] correctly 1`] = `
<div class="sd-space sd-space-horizontal sd-space-align-center" style="column-gap: 40px; row-gap: 40px;">
  <!---->
  <div class="sd-space-item"><span class="sd-badge"><div class="sd-avatar sd-avatar-square"><span class="sd-avatar-text"></span>
    <!--v-if-->
  </div><span class="sd-badge-number"><span>9</span></span></span>
</div>
<!---->
<div class="sd-space-item"><span class="sd-badge"><div class="sd-avatar sd-avatar-square"><span class="sd-avatar-text"></span>
  <!--v-if-->
</div><span class="sd-badge-dot" style="width: 10px; height: 10px;"></span></span></div>
<!---->
<div class="sd-space-item"><span class="sd-badge"><div class="sd-avatar sd-avatar-square"><span class="sd-avatar-text"></span>
  <!--v-if-->
</div><span class="sd-badge-custom-dot" style="height: 16px; width: 16px; font-size: 14px;"><svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" viewBox="0 0 48 48" class="sd-icon sd-icon-clock-circle sd:align-middle sd:text-[var(--color-text-2)]" stroke-width="4" stroke-linecap="butt" stroke-linejoin="miter"><path d="M24 14v10h9.5m8.5 0c0 9.941-8.059 18-18 18S6 33.941 6 24 14.059 6 24 6s18 8.059 18 18Z"></path></svg></span></span></div>
</div>
`;

