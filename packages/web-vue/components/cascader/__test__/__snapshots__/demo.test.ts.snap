exports[`<cascader> demo: > render [migration] correctly 1`] = `
<div class="sd-space sd-space-vertical sd-space-fill" style="column-gap: 24px; row-gap: 24px;">
  <!---->
  <div class="sd-space-item">
    <div>
      <div style="margin-bottom: 8px; font-weight: 600;">先兼容迁移</div>
      <div style="margin-bottom: 12px; color: var(--sd-color-text-3);"> 保留 \`value\`、\`show\`、\`filterable\`、\`clearable\`，先把页面替换到当前组件库。 </div>
      <div class="sd-space sd-space-vertical sd-space-fill" style="column-gap: 8px; row-gap: 8px;">
        <!---->
        <div class="sd-space-item"><button class="sd-btn sd-btn-secondary sd-btn-shape-square sd-btn-size-small sd-btn-status-normal" type="button">
            <!--v-if--> 切换 show：关闭
          </button></div>
        <!---->
        <div class="sd-space-item"><span class="sd-select-view-single sd-select-view sd-select-view-size-medium sd-select-view-search" style="width: 320px;"><!----><input class="sd-select-view-input sd-select-view-input-hidden" placeholder="北京 / 朝阳区" value=""><span class="sd-select-view-value"><span style="width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" class="sd-ellipsis sd-ellipsis--single-line"><span class="sd-ellipsis-content">北京 / 朝阳区</span></span>
