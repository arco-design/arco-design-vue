{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "noCheck": true,
    "declarationMap": false,
    "preserveSymlinks": true,
    "allowArbitraryExtensions": true,
    "paths": {
      "@sdata/web-vue": ["./components/index.ts"],
      "@sdata/web-vue/es/icon": ["./components/icon/index.ts"],
      "@sdata/web-vue/es/icon.js": ["./components/icon/index.ts"],
      "@sdata/web-vue/es/locale/lang/*": ["./components/locale/lang/*"]
    },
    "outDir": ".temp-types",
    "rootDir": "."
  },
  "include": ["components/**/*", "global.d.ts"],
  "exclude": ["node_modules", "dist", "lib", "es", "json", "**/__test__/**/*", "**/__demo__/**/*"]
}
