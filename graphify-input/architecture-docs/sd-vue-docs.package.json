{
  "name": "@sd-design/sd-vue-docs",
  "version": "0.0.1",
  "private": true,
  "description": "SD Design 文档站",
  "type": "module",
  "scripts": {
    "dev": "pnpm run docs:vendor && astro dev",
    "dev:serve": "astro dev",
    "start": "pnpm run docs:vendor && astro dev",
    "build": "pnpm run docs:vendor && astro build",
    "build:site": "astro build",
    "verify:theme-runtime": "node ./scripts/verify-theme-runtime-paths.mjs",
    "preview": "pnpm run docs:vendor && astro preview",
    "astro": "astro",
    "docs:prepare": "pnpm --filter @sdata/web-vue run build:module",
    "docs:vendor": "pnpm run docs:prepare && pnpm run docs:vendor:only",
    "docs:vendor:only": "node ./scripts/sync-vendor.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/starlight": "^0.38.3",
    "@astrojs/vue": "^6.0.1",
    "@sdata/web-vue": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@vue/repl": "^4.7.2",
    "astro": "^6.1.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "vite": "~7.3.2",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "rolldown": "^1.0.0"
  }
}
